{
  "id": "color.convert@1",
  "impl_version": 1,
  "summary": "Decode/encode the color transfer function between srgb and linear-srgb with explicit source and destination encodings.",
  "determinism": "bounded",
  "roi": {
    "category": "pointwise"
  },
  "inputs": [
    {
      "name": "image",
      "kind": "Image",
      "required": true,
      "doc": "The color image to re-encode."
    }
  ],
  "outputs": [
    {
      "name": "image",
      "kind": "Image",
      "doc": "The re-encoded image (same extent/layout, target color encoding)."
    }
  ],
  "params": [
    {
      "name": "from",
      "type": "string",
      "required": true,
      "choices": [
        "srgb",
        "linear-srgb",
        "raw-linear"
      ],
      "doc": "The source color encoding of the input image."
    },
    {
      "name": "to",
      "type": "string",
      "required": true,
      "choices": [
        "srgb",
        "linear-srgb",
        "raw-linear"
      ],
      "doc": "The destination color encoding to produce."
    }
  ],
  "implementations": [
    "cpu.reference@1"
  ],
  "test": {
    "has_analytic_reference": true,
    "has_property_tests": true,
    "verification": {
      "build-hygiene": {
        "status": "covered"
      },
      "schema-contract": {
        "status": "covered"
      },
      "analytic-fixtures": {
        "status": "covered"
      },
      "property-tests": {
        "status": "covered"
      },
      "metamorphic": {
        "status": "covered"
      },
      "goldens": {
        "status": "covered"
      },
      "perceptual": {
        "status": "not-applicable",
        "reason": "color.convert is a closed-form numeric transfer function verified by an analytic value table and a tolerance round-trip; there is no perceptual-quality metric to apply"
      },
      "fuzzing": {
        "status": "covered"
      },
      "performance": {
        "status": "covered"
      }
    }
  }
}
