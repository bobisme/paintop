    },
    {
      "name": "b",
      "kind": "SdfMask",
      "required": true,
      "doc": "The right-hand signed distance field (same extent as `a`)."
    }
  ],
  "outputs": [
    {
      "name": "sdf",
      "kind": "SdfMask",
      "doc": "The intersection field max(phi_a, phi_b) (negative-inside)."
    }
  ],
